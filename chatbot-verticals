"""
main.py — FastAPI chatbot routes
Covers:
  • GET/PUT  /chatbot/config/{store_id}      — FAQ + bot identity config
  • POST     /chatbot/chat                   — AI chat (FAQ RAG + Phi-4 fallback)
  • POST     /chatbot/refund                 — Razorpay refund initiation
  • POST     /chatbot/return                 — Product return + image defect check
"""

