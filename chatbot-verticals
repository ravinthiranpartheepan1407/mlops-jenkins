from dotenv import load_dotenv
load_dotenv()

# ── Azure / Phi-4 config ──────────────────────────────────────────────────────
from azure.ai.inference import ChatCompletionsClient
from azure.ai.inference.models import UserMessage, SystemMessage
from azure.core.credentials import AzureKeyCredential

AZURE_API_URL = os.environ.get("API_URL")
AZURE_API_KEY = os.environ.get("API_KEY")
AZURE_MODEL   = "Phi-4"

# ── Razorpay config ───────────────────────────────────────────────────────────
RAZORPAY_KEY_ID     = os.environ.get("RAZORPAY_KEY_ID",     "")
RAZORPAY_KEY_SECRET = os.environ.get("RAZORPAY_KEY_SECRET", "")

# ── App setup ─────────────────────────────────────────────────────────────────
app = FastAPI(title="Store Chatbot API")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

from fastapi.exceptions import RequestValidationError

@app.exception_handler(RequestValidationError)
async def validation_exception_handler(request: Request, exc: RequestValidationError):
    body = await request.body()
    print(f"[422] Path: {request.url.path} | Body: {body.decode()} | Errors: {exc.errors()}")
    return JSONResponse(
        status_code=422,
        content={"detail": exc.errors(), "body_received": body.decode()},
    )

